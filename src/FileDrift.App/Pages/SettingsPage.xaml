<Page x:Class="FileDrift.App.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Settings"
      FontSize="13">
    <StackPanel Margin="20,12,20,12">
        <ui:TextBlock Text="Settings" FontTypography="Subtitle" Margin="0,0,0,16" />

        <ui:CardControl Icon="{ui:SymbolIcon Color24}" Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="Preset" FontTypography="BodyStrong" />
                    <ui:TextBlock Text="One-click color scheme (Light base, sets accent, title bar, and background)"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="PresetBox" Width="170" SelectionChanged="OnPresetChanged" />
        </ui:CardControl>

        <ui:CardControl Icon="{ui:SymbolIcon WeatherMoon24}" Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="Theme" FontTypography="BodyStrong" />
                    <ui:TextBlock Text="Follow the OS (System), or force Light or Dark"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="ThemeBox" Width="170" SelectionChanged="OnManualChanged">
                <ComboBoxItem Content="System" />
                <ComboBoxItem Content="Light" />
                <ComboBoxItem Content="Dark" />
            </ComboBox>
        </ui:CardControl>

        <ui:CardControl Icon="{ui:SymbolIcon InkingTool24}" Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="Accent color" FontTypography="BodyStrong" />
                    <ui:TextBlock Text="Buttons, selection, and highlights"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="AccentBox" Width="170" SelectionChanged="OnManualChanged" />
        </ui:CardControl>

        <ui:CardControl Icon="{ui:SymbolIcon PaintBrush24}" Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="Title bar" FontTypography="BodyStrong" />
                    <ui:TextBlock Text="Tint the title bar, or Default for the Mica backdrop"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="TitleBarBox" Width="170" SelectionChanged="OnManualChanged" />
        </ui:CardControl>

        <ui:CardControl Icon="{ui:SymbolIcon Info24}" Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="Version" FontTypography="BodyStrong" />
                    <ui:TextBlock x:Name="VersionText" Text="—"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl Icon="{ui:SymbolIcon Database24}">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="History database" FontTypography="BodyStrong" />
                    <ui:TextBlock x:Name="DbPathText" Text="—"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                                  TextWrapping="Wrap" />
                </StackPanel>
            </ui:CardControl.Header>
        </ui:CardControl>
    </StackPanel>
</Page>
