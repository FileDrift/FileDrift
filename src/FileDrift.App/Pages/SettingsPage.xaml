<Page x:Class="FileDrift.App.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Settings"
      FontSize="13">
    <StackPanel Margin="20,12,20,12">
        <ui:TextBlock Text="Settings" FontTypography="Subtitle" Margin="0,0,0,16" />

        <ui:CardControl Icon="{ui:SymbolIcon Color24}" Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="Preset" FontTypography="BodyStrong" />
                    <ui:TextBlock Text="One-click color scheme (Light base, sets accent, title bar, and background)"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="PresetBox" Width="170" SelectionChanged="OnPresetChanged" />
        </ui:CardControl>

        <ui:CardControl Icon="{ui:SymbolIcon WeatherMoon24}" Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="Theme" FontTypography="BodyStrong" />
                    <ui:TextBlock Text="Follow the OS (System), or force Light or Dark"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="ThemeBox" Width="170" SelectionChanged="OnManualChanged">
                <ComboBoxItem Content="System" />
                <ComboBoxItem Content="Light" />
                <ComboBoxItem Content="Dark" />
            </ComboBox>
        </ui:CardControl>

        <ui:CardControl Icon="{ui:SymbolIcon InkingTool24}" Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="Accent color" FontTypography="BodyStrong" />
                    <ui:TextBlock Text="Buttons, selection, and highlights"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="AccentBox" Width="170" SelectionChanged="OnManualChanged" />
        </ui:CardControl>

        <ui:CardControl Icon="{ui:SymbolIcon PaintBrush24}" Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="Title bar" FontTypography="BodyStrong" />
                    <ui:TextBlock Text="Tint the title bar, or Default for the Mica backdrop"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="TitleBarBox" Width="170" SelectionChanged="OnManualChanged" />
        </ui:CardControl>

        <ui:CardControl Icon="{ui:SymbolIcon Color24}" Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="Custom accent (hex)" FontTypography="BodyStrong" />
                    <ui:TextBlock Text="Type a #RRGGBB color and click Set to use it as the accent"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border x:Name="HexSwatch" Width="24" Height="24" CornerRadius="4" Margin="0,0,8,0"
                        BorderThickness="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}" />
                <ui:TextBox x:Name="HexBox" Width="110" PlaceholderText="#RRGGBB" TextChanged="OnHexTextChanged" />
                <ui:Button x:Name="HexSetButton" Content="Set" Margin="8,0,0,0" Click="OnHexSet" />
            </StackPanel>
        </ui:CardControl>

        <ui:CardControl Icon="{ui:SymbolIcon Save24}" Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="Save current as preset" FontTypography="BodyStrong" />
                    <ui:TextBlock Text="Stores the current theme and colors under a name (presets.json)"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:TextBox x:Name="PresetNameBox" Width="150" PlaceholderText="Preset name" />
                <ui:Button x:Name="SavePresetButton" Content="Save" Margin="8,0,0,0" Click="OnSavePreset" />
            </StackPanel>
        </ui:CardControl>

        <ui:CardControl Icon="{ui:SymbolIcon Timer24}" Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="Live refresh" FontTypography="BodyStrong" />
                    <ui:TextBlock Text="How often the live readouts on the Verify page (activity log and transfer rate) refresh during a run (the log file keeps every line)"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Slider x:Name="LogThrottleSlider" Width="170" Minimum="0.5" Maximum="10"
                        TickFrequency="0.5" IsSnapToTickEnabled="True" VerticalAlignment="Center"
                        ValueChanged="OnLogThrottleChanged" />
                <ui:TextBlock x:Name="LogThrottleValue" Text="3.0 s" Width="48" Margin="10,0,0,0"
                              VerticalAlignment="Center" HorizontalAlignment="Right" />
            </StackPanel>
        </ui:CardControl>

        <ui:CardControl Icon="{ui:SymbolIcon Info24}" Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="Version" FontTypography="BodyStrong" />
                    <ui:TextBlock x:Name="VersionText" Text="–"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl Icon="{ui:SymbolIcon Database24}">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="History database" FontTypography="BodyStrong" />
                    <ui:TextBlock x:Name="DbPathText" Text="–"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                                  TextWrapping="Wrap" />
                </StackPanel>
            </ui:CardControl.Header>
        </ui:CardControl>
    </StackPanel>
</Page>
