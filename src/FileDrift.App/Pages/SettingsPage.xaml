<Page x:Class="FileDrift.App.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Settings"
      FontSize="13">
    <StackPanel Margin="20,12,20,12">
        <ui:TextBlock Text="Settings" FontTypography="Subtitle" Margin="0,0,0,16" />

        <ui:CardControl Icon="{ui:SymbolIcon PaintBrush24}" Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="Theme" FontTypography="BodyStrong" />
                    <ui:TextBlock Text="Light or dark base scheme"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="ThemeBox" Width="150" SelectionChanged="OnThemeChanged">
                <ComboBoxItem Content="Light" />
                <ComboBoxItem Content="Dark" />
            </ComboBox>
        </ui:CardControl>

        <ui:CardControl Icon="{ui:SymbolIcon Color24}" Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="Accent color" FontTypography="BodyStrong" />
                    <ui:TextBlock Text="Recolors buttons, selection, and highlights"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="AccentBox" Width="150" SelectionChanged="OnAccentChanged" />
        </ui:CardControl>

        <ui:CardControl Icon="{ui:SymbolIcon Info24}" Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="Version" FontTypography="BodyStrong" />
                    <ui:TextBlock x:Name="VersionText" Text="—"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl Icon="{ui:SymbolIcon Database24}">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock Text="History database" FontTypography="BodyStrong" />
                    <ui:TextBlock x:Name="DbPathText" Text="—"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                                  TextWrapping="Wrap" />
                </StackPanel>
            </ui:CardControl.Header>
        </ui:CardControl>
    </StackPanel>
</Page>
