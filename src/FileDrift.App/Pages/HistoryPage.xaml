<Page x:Class="FileDrift.App.Pages.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="History">
    <Grid Margin="24,16,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <ui:TextBlock Text="History" FontTypography="Title" VerticalAlignment="Center" Margin="0,0,16,0" />
                <ui:TextBlock Text="Show" VerticalAlignment="Center" Margin="0,0,8,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                <ComboBox x:Name="ShowFilterBox" Width="140" VerticalAlignment="Center"
                          SelectionChanged="OnShowFilterChanged">
                    <ComboBoxItem Content="All" IsSelected="True" />
                    <ComboBoxItem Content="Last 7 days" />
                    <ComboBoxItem Content="Last 30 days" />
                    <ComboBoxItem Content="Last 90 days" />
                </ComboBox>
            </StackPanel>
            <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowClockwise24}" HorizontalAlignment="Right"
                       Click="OnRefresh" />
        </Grid>

        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <ui:Button x:Name="SignOffButton" Content="Sign off" Icon="{ui:SymbolIcon Checkmark24}"
                       Appearance="Primary" Click="OnSignOff" Margin="0,0,8,8"
                       ToolTip="Record review sign-off for the selected run." />
            <ui:Button x:Name="CertButton" Content="Export certificate" Icon="{ui:SymbolIcon DocumentRibbon24}"
                       Margin="0,0,8,8" Click="OnExportCertificate"
                       ToolTip="Save an HTML certificate of verification for the selected run." />
            <ui:Button Content="Verify certificate…" Icon="{ui:SymbolIcon DocumentCheckmark24}"
                       Margin="0,0,8,8" Click="OnVerifyCertificate"
                       ToolTip="Open a certificate file and check it has not been altered." />
            <ui:Button Content="Export history…" Icon="{ui:SymbolIcon ArrowExportUp24}"
                       Margin="0,0,8,8" Click="OnExportHistory"
                       ToolTip="Save the runs currently shown (per the Show filter above) to a JSON file." />
            <ui:Button Content="Import history…" Icon="{ui:SymbolIcon ArrowImport24}"
                       Margin="0,0,8,8" Click="OnImportHistory"
                       ToolTip="Load runs from a previously exported JSON file. Never overwrites a locally signed-off run." />
            <ui:Button Content="Clear unsigned…" Icon="{ui:SymbolIcon Delete24}" Appearance="Danger"
                       Margin="0,0,0,8" Click="OnClearUnsigned"
                       ToolTip="Permanently delete unsigned runs. Signed-off runs are never affected." />
        </WrapPanel>

        <DataGrid x:Name="HistoryGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" CanUserAddRows="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Started" Binding="{Binding Started}" Width="160" />
                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="*" />
                <DataGridTextColumn Header="Destination" Binding="{Binding Dest}" Width="*" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                <DataGridTextColumn Header="Matched" Binding="{Binding Matched}" Width="90" />
                <DataGridTextColumn Header="Differences" Binding="{Binding Differences}" Width="100" />
                <DataGridTextColumn Header="Inaccessible" Binding="{Binding Inaccessible}" Width="100" />
                <DataGridTextColumn Header="Signed off" Binding="{Binding SignedOff}" Width="150" />
                <DataGridTextColumn Header="By" Binding="{Binding SignedOffBy}" Width="160" />
            </DataGrid.Columns>
        </DataGrid>

        <ui:TextBlock x:Name="StatusText" Grid.Row="3" Margin="2,10,0,0"
                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
    </Grid>
</Page>
