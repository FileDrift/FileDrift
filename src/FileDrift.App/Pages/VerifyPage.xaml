<Page x:Class="FileDrift.App.Pages.VerifyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Verify"
      FontSize="13">
    <Grid Margin="20,12,20,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TextBlock Grid.Row="0" Text="Verify" FontTypography="Subtitle" Margin="0,0,0,10" />

        <!-- Paths + per-path credentials -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="78" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ui:TextBlock Grid.Row="0" Grid.Column="0" Text="Source" VerticalAlignment="Center"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <ui:TextBox x:Name="SourceBox" Grid.Row="0" Grid.Column="1" Margin="0,0,8,6"
                        PlaceholderText="\\server\share or D:\data" TextChanged="OnSourceChanged" />
            <ComboBox x:Name="SourceCredBox" Grid.Row="0" Grid.Column="2" Width="150" Margin="0,0,8,6"
                      ToolTip="Credential to authenticate the source share" SelectionChanged="OnCredentialChanged" />
            <ui:Button Grid.Row="0" Grid.Column="3" Content="Browse" Margin="0,0,0,6"
                       Icon="{ui:SymbolIcon FolderOpen24}" Click="OnBrowseSource" />

            <ui:TextBlock Grid.Row="1" Grid.Column="0" Text="Destination" VerticalAlignment="Center"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <ui:TextBox x:Name="DestBox" Grid.Row="1" Grid.Column="1" Margin="0,0,8,0"
                        PlaceholderText="\\server2\share2 or E:\backup" TextChanged="OnDestChanged" />
            <ComboBox x:Name="DestCredBox" Grid.Row="1" Grid.Column="2" Width="150" Margin="0,0,8,0"
                      ToolTip="Credential to authenticate the destination share" SelectionChanged="OnCredentialChanged" />
            <ui:Button Grid.Row="1" Grid.Column="3" Content="Browse"
                       Icon="{ui:SymbolIcon FolderOpen24}" Click="OnBrowseDest" />
        </Grid>

        <!-- Options -->
        <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,4">
            <StackPanel Orientation="Horizontal" Margin="0,0,18,8" VerticalAlignment="Center"
                        ToolTip="What to compare on each matched file. Quick = size only · Standard = size + last-write time · Full = size + time + content hash. Deeper is slower.">
                <ui:TextBlock Text="Depth" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ComboBox x:Name="DepthBox" Width="150" SelectedIndex="1" SelectionChanged="OnDepthChanged">
                    <ComboBoxItem Content="Quick (size)" />
                    <ComboBoxItem Content="Standard (+ time)" />
                    <ComboBoxItem Content="Full (+ hash)" />
                </ComboBox>
            </StackPanel>

            <StackPanel x:Name="HashPanel" Orientation="Horizontal" Margin="0,0,18,8" VerticalAlignment="Center"
                        Visibility="Collapsed"
                        ToolTip="Hash algorithm used at Full depth. MD5 is fastest and fine for drift detection; SHA-256 is strongest. Only same-size files are hashed.">
                <ui:TextBlock Text="Hash" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ComboBox x:Name="HashBox" Width="100" SelectedIndex="0">
                    <ComboBoxItem Content="MD5" />
                    <ComboBoxItem Content="SHA1" />
                    <ComboBoxItem Content="SHA256" />
                </ComboBox>
            </StackPanel>

            <ui:ToggleSwitch x:Name="AclSwitch" Content="Compare ACLs" Margin="0,0,10,8" VerticalAlignment="Center"
                             Checked="OnAclChanged" Unchecked="OnAclChanged"
                             ToolTip="Compare explicit (non-inherited) permissions. Inherited permissions are ignored (they differ structurally between servers). Enumerates directories too; slower." />

            <ComboBox x:Name="AclScopeBox" Width="128" Margin="0,0,18,8" VerticalAlignment="Center" SelectedIndex="0" IsEnabled="False"
                      ToolTipService.ShowOnDisabled="True"
                      ToolTip="ACL scope. Files + folders = complete (reads every file's permissions; slow). Folders only = fast (reads folder permissions only – explicit perms usually live on folders), but misses a permission set directly on an individual file.">
                <ComboBoxItem Content="Files + folders" />
                <ComboBoxItem Content="Folders only" />
            </ComboBox>

            <ui:ToggleSwitch x:Name="OwnerSwitch" Content="Enforce ownership" Margin="0,0,18,8" VerticalAlignment="Center"
                             ToolTipService.ShowOnDisabled="True"
                             ToolTip="Only applies with Compare ACLs. Also require the owner to match (and copy it on reconcile). Off by default – owners often differ across servers without being meaningful drift." />

            <ui:ToggleSwitch x:Name="StrictSwitch" Content="Strict Mode" Margin="0,0,18,8" VerticalAlignment="Center"
                             Checked="OnStrictChanged" Unchecked="OnStrictChanged"
                             ToolTipService.ShowOnDisabled="True" ToolTipService.InitialShowDelay="300"
                             ToolTip="Exact match: forces Full depth, SHA-256, ACL comparison, and zero timestamp tolerance. Any byte, permission, or timestamp difference counts as a difference." />

            <StackPanel Orientation="Horizontal" Margin="0,0,18,8" VerticalAlignment="Center"
                        ToolTip="Parallel workers for enumeration and hashing. Defaults to 50% of logical processors. Raise for fast disks, lower to limit load. Range 1–64.">
                <ui:TextBlock Text="Threads" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ui:TextBox x:Name="ThreadsBox" Width="56" MaxLength="2"
                            PreviewTextInput="OnThreadsInput" />
                <ui:TextBlock x:Name="ThreadsHint" VerticalAlignment="Center" Margin="6,0,0,0"
                              Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="12" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,18,8" VerticalAlignment="Center"
                        ToolTip="Comma-separated wildcard patterns to skip. * and ? are supported, matched against file name or relative path. Example: *.tmp, ~$*, logs\*">
                <ui:TextBlock Text="Exclude" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ui:TextBox x:Name="ExcludeBox" Width="200" PlaceholderText="*.tmp, ~$*  (comma-separated)" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,18,8" VerticalAlignment="Center"
                        ToolTip="Optional lower bound on last-modified date. Files modified BEFORE this are ignored on BOTH sides (e.g. consolidating into a destination that already holds older content). Leave blank for no lower bound.">
                <ui:TextBlock Text="Start" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <DatePicker x:Name="StartBox" Width="120" SelectedDateFormat="Short" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center"
                        ToolTip="Optional upper bound on last-modified date. Destination files modified AFTER this with no source match are excluded as post-migration noise; files present on both sides are always compared. Leave blank for no upper bound.">
                <ui:TextBlock Text="End" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <DatePicker x:Name="EndBox" Width="120" SelectedDateFormat="Short" />
            </StackPanel>
        </WrapPanel>

        <!-- Actions + mode readout -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <ui:Button x:Name="PreflightButton" Content="Preflight"
                           Icon="{ui:SymbolIcon Search24}" Click="OnPreflightClick"
                           ToolTip="Validate access and counts before verifying – run this first" />
                <ui:Button x:Name="VerifyButton" Content="Verify" Appearance="Primary" Margin="8,0,0,0"
                           Icon="{ui:SymbolIcon Play24}" Click="OnVerifyClick" />
                <ui:Button x:Name="CancelButton" Content="Cancel" Margin="8,0,0,0" Appearance="Danger"
                           Icon="{ui:SymbolIcon Stop24}" Click="OnCancelClick" Visibility="Collapsed" />
                <Border Width="1" Margin="12,2,12,2" Background="{DynamicResource ControlElevationBorderBrush}" />
                <ui:Button x:Name="PreviewButton" Content="Preview" IsEnabled="False"
                           Icon="{ui:SymbolIcon Eye24}" Click="OnPreviewClick"
                           ToolTip="List what Reconcile would copy/overwrite, without changing anything" />
                <ui:Button x:Name="ReconcileButton" Content="Reconcile" Margin="8,0,0,0" IsEnabled="False"
                           Icon="{ui:SymbolIcon ArrowSync24}" Click="OnReconcileClick"
                           ToolTip="Copy source→destination to fix missing and different files. Source is the source of truth; nothing is deleted." />
            </StackPanel>
            <ui:TextBlock x:Name="ModeText" HorizontalAlignment="Right" VerticalAlignment="Center"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
        </Grid>

        <!-- Progress -->
        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <ProgressBar x:Name="ProgressBar" Height="4" Minimum="0" Maximum="100" Value="0" />
            <Grid Margin="0,6,0,0">
                <ui:TextBlock x:Name="StatusText" Text="Ready" HorizontalAlignment="Left"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                <ui:TextBlock x:Name="RateText" Text="" HorizontalAlignment="Right"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                              ToolTip="Write throughput to the destination, averaged over the last several seconds (measures bytes written by FileDrift; over buffered SMB it can briefly run ahead of the wire). The '~ … left' estimate is approximate — it is that recent average rate applied to the bytes remaining, and will drift if the rate changes." />
            </Grid>
            <ui:InfoBar x:Name="PreviewBar" Margin="0,8,0,0" IsOpen="False" IsClosable="True"
                        Severity="Informational" Title="Preview" />
            <ui:InfoBar x:Name="ResultBar" Margin="0,8,0,0" IsOpen="False" IsClosable="True"
                        Severity="Warning" Title="Incomplete comparison" />
        </StackPanel>

        <!-- Summary -->
        <UniformGrid Grid.Row="5" Columns="4" Margin="0,0,0,12">
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Margin="0,0,5,0" Padding="12,8">
                <StackPanel>
                    <ui:TextBlock x:Name="MatchedLabel" Text="Matched" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <ui:TextBlock x:Name="MatchedText" Text="–" FontTypography="BodyStrong" FontSize="18" />
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Margin="2.5,0,2.5,0" Padding="12,8">
                <StackPanel>
                    <ui:TextBlock x:Name="DifferentLabel" Text="Different" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <ui:TextBlock x:Name="DifferentText" Text="–" FontTypography="BodyStrong" FontSize="18" />
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Margin="2.5,0,2.5,0" Padding="12,8">
                <StackPanel>
                    <ui:TextBlock x:Name="MissingLabel" Text="Missing at dest" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <ui:TextBlock x:Name="MissingText" Text="–" FontTypography="BodyStrong" FontSize="18" />
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Margin="5,0,0,0" Padding="12,8">
                <StackPanel>
                    <ui:TextBlock x:Name="ExtraLabel" Text="Extra at dest" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <ui:TextBlock x:Name="ExtraText" Text="–" FontTypography="BodyStrong" FontSize="18" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Activity log -->
        <Grid Grid.Row="6" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ui:TextBlock Grid.Row="0" Text="Activity" FontTypography="BodyStrong" FontSize="12" Margin="0,0,0,3" />
            <Border Grid.Row="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                <ListBox x:Name="ActivityLog" Height="80" BorderThickness="0"
                         FontFamily="Cascadia Mono, Consolas, Courier New" FontSize="11"
                         Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         VirtualizingStackPanel.IsVirtualizing="True">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="6,1" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>
            <Grid Grid.Row="2" Margin="0,6,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <ui:Button x:Name="CopyLogButton" Content="Copy activity log" Appearance="Primary"
                               Icon="{ui:SymbolIcon Copy24}"
                               Click="OnCopyLogClick" ToolTip="Copy the full activity log to the clipboard" />
                    <ui:Button x:Name="OpenLogButton" Content="Open log file" Margin="8,0,0,0" IsEnabled="False"
                               Icon="{ui:SymbolIcon DocumentText24}"
                               Click="OnOpenLogClick" ToolTip="Open this run's complete log file (includes the full difference list)" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ui:Button x:Name="VerifySignOffButton" Content="Sign off" Icon="{ui:SymbolIcon Checkmark24}"
                               Appearance="Primary" Click="OnVerifySignOff" IsEnabled="False"
                               ToolTip="Record review sign-off for the completed run shown below." />
                    <ui:Button x:Name="VerifyCertButton" Content="Export certificate" Icon="{ui:SymbolIcon DocumentRibbon24}"
                               Margin="8,0,0,0" Click="OnVerifyExportCertificate" IsEnabled="False"
                               ToolTip="Save an HTML certificate of verification for the completed run shown below." />
                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center"
                                ToolTip="How often the live readouts (activity log and transfer rate) refresh during a run. Takes effect immediately, even mid-run. Also set in Settings.">
                        <ui:TextBlock Text="Live refresh" VerticalAlignment="Center" Margin="0,0,8,0"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11" />
                        <Slider x:Name="VerifyLogThrottleSlider" Width="110" Minimum="0.5" Maximum="10"
                                TickFrequency="0.5" IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                ValueChanged="OnVerifyLogThrottleChanged" />
                        <ui:TextBlock x:Name="VerifyLogThrottleValue" Text="3.0 s" Width="40" Margin="6,0,0,0"
                                      VerticalAlignment="Center" FontSize="11" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Results -->
        <DataGrid x:Name="ResultsGrid" Grid.Row="7" AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" CanUserAddRows="False"
                  FontSize="12" RowHeight="26"
                  EnableRowVirtualization="True" EnableColumnVirtualization="False"
                  ScrollViewer.CanContentScroll="True"
                  VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                <DataGridTextColumn Header="Difference" Binding="{Binding Differences}" Width="140" />
                <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
