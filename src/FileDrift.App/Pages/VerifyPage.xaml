<Page x:Class="FileDrift.App.Pages.VerifyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Verify"
      FontSize="13">
    <Grid Margin="20,12,20,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TextBlock Grid.Row="0" Text="Verify" FontTypography="Subtitle" Margin="0,0,0,10" />

        <!-- Paths + per-path credentials -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="78" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ui:TextBlock Grid.Row="0" Grid.Column="0" Text="Source" VerticalAlignment="Center"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <ui:TextBox x:Name="SourceBox" Grid.Row="0" Grid.Column="1" Margin="0,0,8,6"
                        PlaceholderText="\\server\share or D:\data" TextChanged="OnSourceChanged" />
            <ComboBox x:Name="SourceCredBox" Grid.Row="0" Grid.Column="2" Width="150" Margin="0,0,8,6"
                      ToolTip="Credential to authenticate the source share" />
            <ui:Button Grid.Row="0" Grid.Column="3" Content="Browse" Margin="0,0,0,6"
                       Icon="{ui:SymbolIcon FolderOpen24}" Click="OnBrowseSource" />

            <ui:TextBlock Grid.Row="1" Grid.Column="0" Text="Destination" VerticalAlignment="Center"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <ui:TextBox x:Name="DestBox" Grid.Row="1" Grid.Column="1" Margin="0,0,8,0"
                        PlaceholderText="\\server2\share2 or E:\backup" TextChanged="OnDestChanged" />
            <ComboBox x:Name="DestCredBox" Grid.Row="1" Grid.Column="2" Width="150" Margin="0,0,8,0"
                      ToolTip="Credential to authenticate the destination share" />
            <ui:Button Grid.Row="1" Grid.Column="3" Content="Browse"
                       Icon="{ui:SymbolIcon FolderOpen24}" Click="OnBrowseDest" />
        </Grid>

        <!-- Options -->
        <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,4">
            <StackPanel Orientation="Horizontal" Margin="0,0,18,8" VerticalAlignment="Center"
                        ToolTip="What to compare on each matched file. Quick = size only · Standard = size + last-write time · Full = size + time + content hash. Deeper is slower.">
                <ui:TextBlock Text="Depth" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ComboBox x:Name="DepthBox" Width="150" SelectedIndex="1" SelectionChanged="OnDepthChanged">
                    <ComboBoxItem Content="Quick (size)" />
                    <ComboBoxItem Content="Standard (+ time)" />
                    <ComboBoxItem Content="Full (+ hash)" />
                </ComboBox>
            </StackPanel>

            <StackPanel x:Name="HashPanel" Orientation="Horizontal" Margin="0,0,18,8" VerticalAlignment="Center"
                        Visibility="Collapsed"
                        ToolTip="Hash algorithm used at Full depth. MD5 is fastest and fine for drift detection; SHA-256 is strongest. Only same-size files are hashed.">
                <ui:TextBlock Text="Hash" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ComboBox x:Name="HashBox" Width="100" SelectedIndex="0">
                    <ComboBoxItem Content="MD5" />
                    <ComboBoxItem Content="SHA1" />
                    <ComboBoxItem Content="SHA256" />
                </ComboBox>
            </StackPanel>

            <ui:ToggleSwitch x:Name="AclSwitch" Content="Compare ACLs" Margin="0,0,18,8" VerticalAlignment="Center"
                             ToolTip="Also compare each file's owner and permissions (SDDL). Slower; reads security descriptors for every matched pair." />

            <ui:ToggleSwitch x:Name="StrictSwitch" Content="Strict Mode" Margin="0,0,18,8" VerticalAlignment="Center"
                             Checked="OnStrictChanged" Unchecked="OnStrictChanged"
                             ToolTipService.ShowOnDisabled="True" ToolTipService.InitialShowDelay="300"
                             ToolTip="Exact match: forces Full depth, SHA-256, ACL comparison, and zero timestamp tolerance. Any byte, permission, or timestamp difference counts as a difference." />

            <StackPanel Orientation="Horizontal" Margin="0,0,18,8" VerticalAlignment="Center"
                        ToolTip="Parallel workers for enumeration and hashing. Defaults to 50% of logical processors. Raise for fast disks, lower to limit load. Range 1–64.">
                <ui:TextBlock Text="Threads" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ui:TextBox x:Name="ThreadsBox" Width="56" MaxLength="2"
                            PreviewTextInput="OnThreadsInput" />
                <ui:TextBlock x:Name="ThreadsHint" VerticalAlignment="Center" Margin="6,0,0,0"
                              Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="12" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center"
                        ToolTip="Comma-separated wildcard patterns to skip. * and ? are supported, matched against file name or relative path. Example: *.tmp, ~$*, logs\*">
                <ui:TextBlock Text="Exclude" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ui:TextBox x:Name="ExcludeBox" Width="200" PlaceholderText="*.tmp, ~$*  (comma-separated)" />
            </StackPanel>
        </WrapPanel>

        <!-- Actions + mode readout -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <ui:Button x:Name="VerifyButton" Content="Verify" Appearance="Primary"
                           Icon="{ui:SymbolIcon Play24}" Click="OnVerifyClick" />
                <ui:Button x:Name="CancelButton" Content="Cancel" Margin="8,0,0,0"
                           Icon="{ui:SymbolIcon Stop24}" Click="OnCancelClick" Visibility="Collapsed" />
                <ui:Button x:Name="PreflightButton" Content="Preflight" Margin="8,0,0,0"
                           Icon="{ui:SymbolIcon Search24}" Click="OnPreflightClick"
                           ToolTip="Check accessibility and counts without comparing" />
            </StackPanel>
            <ui:TextBlock x:Name="ModeText" HorizontalAlignment="Right" VerticalAlignment="Center"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
        </Grid>

        <!-- Progress -->
        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <ProgressBar x:Name="ProgressBar" Height="4" Minimum="0" Maximum="100" Value="0" />
            <ui:TextBlock x:Name="StatusText" Text="Ready" Margin="0,6,0,0"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
        </StackPanel>

        <!-- Summary -->
        <UniformGrid Grid.Row="5" Columns="4" Margin="0,0,0,12">
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6" Margin="0,0,5,0" Padding="12,8">
                <StackPanel>
                    <ui:TextBlock Text="Matched" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <ui:TextBlock x:Name="MatchedText" Text="—" FontTypography="BodyStrong" FontSize="18" />
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6" Margin="2.5,0,2.5,0" Padding="12,8">
                <StackPanel>
                    <ui:TextBlock Text="Different" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <ui:TextBlock x:Name="DifferentText" Text="—" FontTypography="BodyStrong" FontSize="18" />
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6" Margin="2.5,0,2.5,0" Padding="12,8">
                <StackPanel>
                    <ui:TextBlock Text="Missing at dest" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <ui:TextBlock x:Name="MissingText" Text="—" FontTypography="BodyStrong" FontSize="18" />
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6" Margin="5,0,0,0" Padding="12,8">
                <StackPanel>
                    <ui:TextBlock Text="Extra at dest" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <ui:TextBlock x:Name="ExtraText" Text="—" FontTypography="BodyStrong" FontSize="18" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Results -->
        <DataGrid x:Name="ResultsGrid" Grid.Row="6" AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" CanUserAddRows="False"
                  FontSize="12" RowHeight="26">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                <DataGridTextColumn Header="Difference" Binding="{Binding Differences}" Width="140" />
                <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
