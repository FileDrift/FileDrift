<Page x:Class="FileDrift.App.Pages.CredentialsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Credentials"
      FontSize="13">
    <Grid Margin="20,12,20,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TextBlock Grid.Row="0" Text="Credentials" FontTypography="Subtitle" Margin="0,0,0,3" />
        <ui:TextBlock Grid.Row="1" Margin="0,0,0,14"
                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                      Text="Stored in Windows Credential Manager (target FileDrift:\\server\share). Visible and editable under Control Panel → Credential Manager." />

        <!-- Default credential -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="16,14" Margin="0,0,0,12">
            <StackPanel>
                <ui:TextBlock Text="Default credential" FontTypography="BodyStrong" />
                <ui:TextBlock Margin="0,2,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                              Text="Used for any share that has no specific credential below. Set this if most shares share one domain account." />
                <Grid x:Name="DefaultStatusRow" Margin="0,0,0,10">
                    <ui:TextBlock x:Name="DefaultStatusText" VerticalAlignment="Center" FontSize="12"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="No default credential set." />
                    <ui:Button x:Name="ClearDefaultButton" Content="Clear default" HorizontalAlignment="Right"
                               Icon="{ui:SymbolIcon Delete24}" Click="OnClearDefault" Visibility="Collapsed" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="User" VerticalAlignment="Center" Margin="0,0,8,0"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:TextBox x:Name="DefaultUserBox" Grid.Column="1" Margin="0,0,16,0" PlaceholderText="domain\user"
                                ToolTip="Account applied to shares without their own credential" />
                    <ui:TextBlock Grid.Column="2" Text="Password" VerticalAlignment="Center" Margin="0,0,8,0"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:PasswordBox x:Name="DefaultPassBox" Grid.Column="3" Margin="0,0,16,0" />
                    <ui:Button Grid.Column="4" Content="Save default" Appearance="Primary"
                               Icon="{ui:SymbolIcon Save24}" Click="OnSaveDefault" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Per-share credential -->
        <Border Grid.Row="3" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="16,14" Margin="0,0,0,12">
            <StackPanel>
                <ui:TextBlock Text="Per-share credential" FontTypography="BodyStrong" />
                <ui:TextBlock Margin="0,2,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                              Text="Override the default for one share. The share root is matched automatically on the Verify page." />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="Share" VerticalAlignment="Center" Margin="0,0,8,0"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:TextBox x:Name="ShareBox" Grid.Column="1" Margin="0,0,16,0" PlaceholderText="\\server\share"
                                ToolTip="A UNC path; reduced to its \\server\share root automatically" />
                    <ui:TextBlock Grid.Column="2" Text="User" VerticalAlignment="Center" Margin="0,0,8,0"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:TextBox x:Name="UserBox" Grid.Column="3" Margin="0,0,16,0" PlaceholderText="domain\user" />
                    <ui:TextBlock Grid.Column="4" Text="Password" VerticalAlignment="Center" Margin="0,0,8,0"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:PasswordBox x:Name="PassBox" Grid.Column="5" Margin="0,0,16,0" />
                    <ui:Button Grid.Column="6" Content="Save" Appearance="Primary"
                               Icon="{ui:SymbolIcon Save24}" Click="OnSave" />
                </Grid>
            </StackPanel>
        </Border>

        <ui:TextBlock x:Name="StatusText" Grid.Row="4" Margin="2,0,0,8"
                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />

        <!-- Saved per-share credentials -->
        <Grid Grid.Row="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <ui:TextBlock Text="Saved per-share credentials" FontTypography="BodyStrong" VerticalAlignment="Center" />
                <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowClockwise24}" Margin="16,0,0,0" Click="OnRefresh" />
                <ui:Button Content="Delete selected" Icon="{ui:SymbolIcon Delete24}" Margin="8,0,0,0" Click="OnDelete" />
                <ui:Button Content="Clear all" Icon="{ui:SymbolIcon DeleteDismiss24}" Margin="8,0,0,0" Click="OnClearAll"
                           ToolTip="Remove every credential FileDrift has stored (per-share and default)." />
            </StackPanel>
            <DataGrid x:Name="CredGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" CanUserAddRows="False"
                      SelectionMode="Single" FontSize="12" RowHeight="26">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Share" Binding="{Binding Share}" Width="*" />
                    <DataGridTextColumn Header="Username" Binding="{Binding User}" Width="220" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>
