<Page x:Class="FileDrift.App.Pages.CredentialsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Credentials"
      FontSize="13">
    <Grid Margin="20,12,20,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TextBlock Grid.Row="0" Text="Credentials" FontTypography="Subtitle" Margin="0,0,0,4" />
        <ui:TextBlock Grid.Row="1" Margin="0,0,0,12"
                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                      Text="Stored in Windows Credential Manager as FileDrift:\\server\share. One credential per share root." />

        <!-- Add / update -->
        <Border Grid.Row="2" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6" Padding="14,12" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBlock Grid.Column="0" Text="Share" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ui:TextBox x:Name="ShareBox" Grid.Column="1" Margin="0,0,12,0" PlaceholderText="\\server\share" />

                <ui:TextBlock Grid.Column="2" Text="User" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ui:TextBox x:Name="UserBox" Grid.Column="3" Margin="0,0,12,0" PlaceholderText="domain\user" />

                <ui:TextBlock Grid.Column="4" Text="Password" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ui:PasswordBox x:Name="PassBox" Grid.Column="5" Margin="0,0,12,0" />

                <ui:Button Grid.Column="6" Content="Save" Appearance="Primary"
                           Icon="{ui:SymbolIcon Save24}" Click="OnSave" />
            </Grid>
        </Border>

        <ui:TextBlock x:Name="StatusText" Grid.Row="2" VerticalAlignment="Bottom" Margin="0,0,0,-6"
                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />

        <!-- Saved credentials -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowClockwise24}" Click="OnRefresh" />
                <ui:Button Content="Delete selected" Icon="{ui:SymbolIcon Delete24}" Margin="8,0,0,0" Click="OnDelete" />
            </StackPanel>
            <DataGrid x:Name="CredGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" CanUserAddRows="False"
                      SelectionMode="Single" FontSize="12" RowHeight="26">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Share" Binding="{Binding Share}" Width="*" />
                    <DataGridTextColumn Header="Username" Binding="{Binding User}" Width="220" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>
